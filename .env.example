# LinkedIn API Client Environment Configuration
LINKEDIN_ACCOUNT=your-linkedin-account

# Browser Use (autonomous browser agent) — store LLM API keys in keyring, not here:
#   keyring set MAMMOUTH_API_KEY browser-use
#   keyring set ANTHROPIC_API_KEY browser-use
# Or export at runtime. Ollama: just run `ollama serve`.
#
# Anthropic via OpenAI-compatible API (https://api.anthropic.com/v1/)
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-5
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/  # optional override
#
# Per-stage models (LUC-51): cheaper for summary, stronger for report.
# LLM_SUMMARY_PROVIDER=ollama
# LLM_SUMMARY_MODEL=llama3.2:3b
# LLM_REPORT_PROVIDER=anthropic
# LLM_REPORT_MODEL=claude-sonnet-4-5
